// plan.md Step 3 의 스키마를 SQLite 로 옮긴 것.
//
// 차이점:
//   - Postgres 의 Json / String[] → SQLite 에서는 native 가 없으므로
//     모두 JSON-stringified String 으로 저장한다. lib/profile-service 가
//     read 시 parse, write 시 stringify 한다.
//   - Postgres 로 옮기려면 provider 와 위 필드 타입만 바꾸면 됨.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- NextAuth ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Domain ----

model User {
  id            String    @id @default(cuid())
  googleId      String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // (DEPRECATED) YouTube OAuth 토큰. YouTube API 호출을 걷어내면서 더 이상
  // 안 쓰지만 마이그레이션 비용을 피하려고 컬럼은 남겨둔다 — 새 로그인부터는
  // 채워지지 않는다.
  accessToken   String?
  refreshToken  String?
  expiresAt     Int?

  isPublic      Boolean   @default(false)

  accounts      Account[]
  sessions      Session[]
  profile       AlgoProfile?
  onboardInput  OnboardInput?

  following     Follow[]  @relation("follower")
  followers     Follow[]  @relation("following")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AlgoProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categories      String   // JSON: { name: percent }
  topChannels     String   // JSON: [{ id, name, thumbnail, videoCount }]
  topKeywords     String   // JSON: string[]
  sampleVideoIds  String   // JSON: string[]
  metrics         String?  // JSON: ProfileMetrics (diversity, shortsRatio, languageDistribution, …)

  // channel_analyze_plan §1: 추천에서 "이미 구독한 채널 제외" 용.
  // sync 시 subscriptions.list 결과(추가 쿼터 0)에서 채워진다.
  subscribedChannelIds String @default("[]") // JSON: string[]

  lastSyncedAt    DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 폼(/onboard) 원본 입력을 보존. AlgoProfile 은 이 입력에서 파생되며,
// 카탈로그/분류기 업데이트 시 재계산할 수 있도록 원본을 따로 둔다.
model OnboardInput {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelIds    String   @default("[]")  // JSON: string[]  — 사용자가 고른 채널
  categories    String   @default("[]")  // JSON: string[]  — 체크한 카테고리 이름
  playlistUrls  String   @default("[]")  // JSON: string[]  — 선택 보강용

  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

// ---- Channel catalog (channel_analyze_plan.md) ----
// 한국 채널(구독자 ≥ 10만) 카탈로그 + 클러스터.
// JSON 필드는 AlgoProfile 과 동일하게 String 직렬화 (lib/channel-service.ts 가 pack/unpack).

model Channel {
  id              String   @id            // YouTube channelId (UC...)
  title           String
  handle          String?
  thumbnail       String   @default("")
  description     String?

  subscriberCount Int      @default(0)
  videoCount      Int      @default(0)
  viewCount       BigInt   @default(0)
  country         String?
  isKorean        Boolean  @default(true)

  categories      String   @default("{}")  // JSON: { name: 0-100 }
  keywords        String   @default("[]")  // JSON: string[]
  metrics         String?                  // JSON: { mainstreamScore, nicheScore, uploadsPerMonth }

  clusterId       Int?
  cluster         ChannelCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  source          String   @default("seed") // seed|trending|search|snowball|mock
  fetchedAt       DateTime @default(now())
  refreshedAt     DateTime @updatedAt

  @@index([clusterId])
  @@index([subscriberCount])
  @@index([isKorean])
}

model ChannelCluster {
  id            Int      @id @default(autoincrement())
  label         String                     // 자동 라벨(top-2 카테고리) — 수기 수정 가능
  centroid      String   @default("{}")    // JSON: { name: weight } 정규화 카테고리 벡터
  topCategories String   @default("[]")    // JSON: [{ name, weight }]
  topKeywords   String   @default("[]")    // JSON: string[]
  size          Int      @default(0)
  color         String?
  channels      Channel[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 수집을 며칠에 걸쳐 재개 가능하게 하는 상태(일일 쿼터 분산).
model CollectionRun {
  id          Int      @id @default(autoincrement())
  status      String   @default("running") // running|paused|done
  acceptedN   Int      @default(0)
  frontier    String   @default("[]")      // JSON: 미탐색 channelId 큐(snowball)
  visited     String   @default("[]")      // JSON: 이미 처리한 channelId
  quotaSpent  Int      @default(0)
  note        String?
  startedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
